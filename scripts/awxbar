#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="/Users/zhang/Desktop/agent-watchdog"
AWX_SCRIPT="$BASE_DIR/scripts/awx"

usage() {
  cat <<'EOF'
用法:
  awxbar [你的命令]

示例:
  awxbar
  awxbar "codex"
  awxbar "python3 app.py"

行为:
  已废弃。请改用 awx。
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ ! -x "$AWX_SCRIPT" ]]; then
  echo "错误：未找到 awx 脚本：$AWX_SCRIPT"
  exit 1
fi

echo "提示：awxbar 已废弃，请改用 awx。"

if [[ $# -eq 0 ]]; then
  exec "$AWX_SCRIPT"
fi

exec "$AWX_SCRIPT" "$@"
